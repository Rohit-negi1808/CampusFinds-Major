# Frontend Environment Variables for Vite
# Note: All variables must have VITE_ prefix to be accessible in Vite projects via import.meta.env

# === VITE_API_URL - Backend API Base URL ===
# 
# Local Development:
#   Copy this to .env.local and set to your backend URL
#   Example: VITE_API_URL=http://localhost:5000
#
# Production (Vercel Deployment):
#   1. Go to https://vercel.com/dashboard
#   2. Select CampusFinds project > Settings > Environment Variables
#   3. Add: VITE_API_URL=https://campusfinds-major.onrender.com
#   4. Redeploy from Git (or trigger redeploy in Vercel)
#
# Accessed in code via: import.meta.env.VITE_API_URL
# Fallback: If undefined, uses /api (Vite proxy in dev, or error in prod)
#
VITE_API_URL=http://localhost:5000
