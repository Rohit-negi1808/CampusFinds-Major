# Frontend Environment Variables for Vite
# Note: All variables must have VITE_ prefix to be accessible in Vite projects

# API Base URL - Set to your deployed backend URL or local development server
# Examples:
#   Development: http://localhost:5000
#   Production: https://campusfinds-major.onrender.com
# This variable is accessed via: import.meta.env.VITE_API_URL
VITE_API_URL=http://localhost:5000
